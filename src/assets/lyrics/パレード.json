      "chinese": "作詞/作曲：平沢进",
      "isBreak": false
    },
    {
      "japanese": "胸にエナジー　ケミカルの泡立ち",
      "furiganaMap": {
        "0": "むね",
        "12": "あわ",
        "13": "だ"
      },
      "chinese": "胸中涌动着能量 化学般翻腾起泡",
      "isBreak": false
    },
    {
      "japanese": "ハイヤー古タイヤや　血や肉の通りを行き",
      "furiganaMap": {
        "4": "ふる",
        "10": "ち",
        "12": "にく",
        "14": "と"
      },
      "chinese": "穿过旧轮胎与血肉之路而行",
      "isBreak": false
    },
    {
      "japanese": "あれがリバティー　ユートピアバロディー",
      "furiganaMap": {
        "5": "ti",
        "16": "di"
      },
      "chinese": "那就是自由 乌托邦的戏仿",
      "isBreak": false
    },
    {
      "japanese": "バイヤーやギガ・ムービーの　絢爛の並木は晴れ",
      "furiganaMap": {
        "14": "けん",
        "15": "らん",
        "17": "なみ",
        "18": "き",
        "20": "は"
      },
      "chinese": "买家与巨幕电影之下 绚烂的林荫道一片晴朗",
      "isBreak": false
    },
    {
      "japanese": "マイナーな鬱は戯言　バラ色は廉価",
      "furiganaMap": {
        "5": "うつ",
        "7": "ざれ",
        "8": "ごと",
        "14": "れん",
        "15": "か"
      },
      "chinese": "小众的忧郁只是戏言 玫瑰色也廉价得很",
      "isBreak": false
    },
    {
      "japanese": "いわく幸せと知れ　持ちきれねほど",
      "furiganaMap": {
        "3": "しあ",
        "6": "し",
        "9": "も"
      },
      "chinese": "所谓幸福啊 要知道它多得几乎捧不住",
      "isBreak": true
    },
    {
      "japanese": "瀕死のリテラシー　メカニカルニ殺す",
      "furiganaMap": {
        "0": "ひん",
        "1": "し",
        "15": "ころ"
      },
      "chinese": "濒死的识读力 被机械地抹杀",
      "isBreak": false
    },
    {
      "japanese": "売人や吊るワイヤーや　ホルムアルデヒドの通り",
      "furiganaMap": {
        "0": "ばい",
        "1": "にん",
        "3": "つ",
        "20": "どお"
      },
      "chinese": "贩子、吊起的钢索 与甲醛之街",
      "isBreak": false
    },
    {
      "japanese": "乾くシナジー　合成スートで湿し",
      "furiganaMap": {
        "0": "かわ",
        "7": "ごう",
        "8": "せい",
        "13": "しめ"
      },
      "chinese": "干涸的协同 用合成套装将其润湿",
      "isBreak": false
    },
    {
      "japanese": "高層のメガ神殿に　狂乱のファンドの雨",
      "furiganaMap": {
        "0": "こう",
        "1": "そう",
        "5": "しん",
        "6": "でん",
        "9": "きょう",
        "10": "らん",
        "17": "あめ"
      },
      "chinese": "高层的巨大神殿里 落下狂乱基金的雨",
      "isBreak": false
    },
    {
      "japanese": "「蒙昧」の文字は書けねど　未来は廉価",
      "furiganaMap": {
        "1": "もう",
        "2": "まい",
        "5": "もん",
        "6": "じ",
        "8": "か",
        "13": "み",
        "14": "らい",
        "16": "れん",
        "17": "か"
      },
      "chinese": "虽写不出“蒙昧”二字 未来却也廉价",
      "isBreak": false
    },
    {
      "japanese": "なべて迷信と笑え　因果のストーリー",
      "furiganaMap": {
        "3": "めい",
        "4": "しん",
        "6": "わら",
        "9": "いん",
        "10": "が"
      },
      "chinese": "把一切都笑作迷信吧 因果的故事罢了",
      "isBreak": true
    },
    {
      "japanese": "さあ異臭を放ちくる　君の影を喰い",
      "furiganaMap": {
        "2": "い",
        "3": "しゅう",
        "5": "はな",
        "10": "きみ",
        "12": "かげ",
        "14": "く"
      },
      "chinese": "来吧 一边散发异臭 一边啃食你的影子",
      "isBreak": false
    },
    {
      "japanese": "恐怖のパレードがくる　君の名の下に",
      "furiganaMap": {
        "0": "きょう",
        "1": "ふ",
        "11": "きみ",
        "13": "な",
        "15": "もと"
      },
      "chinese": "恐怖的游行来了 就在你的名义之下",
      "isBreak": true
    },
    {
      "japanese": "轟音のMC　シビリアンニは致死量",
      "furiganaMap": {
        "0": "ごう",
        "1": "おん",
        "13": "ち",
        "14": "し",
        "15": "りょう"
      },
      "chinese": "轰鸣的MC 对平民而言是致死剂量",
      "isBreak": false
    },
    {
      "japanese": "廃人や売るダイアや　血に墜ちた道理の通り",
      "furiganaMap": {
        "0": "はい",
        "3": "う",
        "10": "ち",
        "12": "お",
        "15": "どう",
        "16": "り",
        "18": "どお"
      },
      "chinese": "废人与待售的钻石 穿过堕入鲜血的道理之街",
      "isBreak": false
    },
    {
      "japanese": "あれがリパディー　ユートピアのパロディー",
      "furiganaMap": {},
      "chinese": "那就是赝品般的自由 乌托邦的戏仿",
      "isBreak": false
    },
    {
      "japanese": "頼みはSSRI　さて流行のテラスでハイホー",
      "furiganaMap": {
        "0": "たの",
        "10": "はや",
        "11": "り"
      },
      "chinese": "仰赖的只有SSRI 那就在流行的露台上喊声嗨哟",
      "isBreak": false
    },
    {
      "japanese": "マイナーな説はたわごと　享楽は廉価",
      "furiganaMap": {
        "5": "せつ",
        "12": "きょう",
        "13": "らく",
        "15": "れん",
        "16": "か"
      },
      "chinese": "冷门的说法不过胡言 享乐也廉价得很",
      "isBreak": false
    },
    {
      "japanese": "努々省みるな　手遅れゆえ",
      "furiganaMap": {
        "0": "ゆめ",
        "2": "かえり",
        "7": "て",
        "8": "おく"
      },
      "chinese": "切莫回头反省 因为早已太迟",
      "isBreak": true
    },
    {
      "japanese": "さあ異臭を放ちくる　君の影を喰い",
      "furiganaMap": {
        "2": "い",
        "3": "しゅう",
        "5": "はな",
        "10": "きみ",
        "12": "かげ",
        "14": "く"
      },
      "chinese": "来吧 一边散发异臭 一边啃食你的影子",
      "isBreak": false
    },
    {
      "japanese": "恐怖のパレードがくる　君の名の下に",
      "furiganaMap": {
        "0": "きょう",
        "1": "ふ",
        "11": "きみ",
        "13": "な",
        "15": "もと"
      },
      "chinese": "恐怖的游行来了 就在你的名义之下",
      "isBreak": false
    },
    {
      "japanese": "さあ地を埋めつくすほど　君の影が産む",
      "furiganaMap": {
        "2": "ち",
        "4": "う",
        "12": "きみ",
        "14": "かげ",
        "16": "う"
      },
      "chinese": "来吧 你的影子所生之物几乎要埋满大地",
      "isBreak": false
