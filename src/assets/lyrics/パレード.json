    {
      "japanese": "狂気のパレードがくる　君の名の下に",
      "furiganaMap": {
        "0": "きょう",
        "1": "き",
        "11": "きみ",
        "13": "な",
        "15": "もと"
      },
      "chinese": "疯狂的游行来了 就在你的名义之下",
      "isBreak": false
