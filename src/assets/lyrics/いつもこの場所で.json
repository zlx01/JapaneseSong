    },
    {
      "japanese": "閉じ込められた 目に見えぬヒカリ",
      "furiganaMap": {
        "0": "と",
        "2": "こ",
        "8": "め",
        "10": "み"
      },
      "chinese": "被封存在其中的是那看不见的光",
      "isBreak": false
    },
    {
