      "furiganaMap": {
        "0": "と",
        "1": "まど",
        "9": "か"
      },
      "chinese": "都将迷惘化作句点",
      "isBreak": true
    },
    {
      "japanese": "いつか僕らが 未来 振り返る時には",
      "furiganaMap": {
        "3": "ぼく",
        "7": "み",
        "8": "らい",
        "10": "ふ",
        "12": "かえ",
        "14": "とき"
      },
      "chinese": "总有一天当我们回首未来之时",
