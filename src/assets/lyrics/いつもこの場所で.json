        "0": "ざん",
        "1": "こく",
        "3": "す",
        "5": "ゆ",
        "8": "とき",
        "10": "なか"
      },
      "chinese": "在残酷流逝的时光之中",
      "isBreak": false
    },
    {
      "japanese": "探し求めていたもの",
      "furiganaMap": {
        "0": "さが",
        "2": "もと"
      },
      "chinese": "寻找追求着的事物",
      "isBreak": false
    },
    {
      "japanese": "すれ違う世界に",
      "furiganaMap": {
        "2": "ちが",
        "4": "せ",
        "5": "かい"
      },
      "chinese": "在彼此交错而过的世界里",
