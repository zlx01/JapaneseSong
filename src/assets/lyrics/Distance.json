{
  "version": "1.0",
  "lyrics": [
    {
      "japanese": "Distance",
      "furiganaMap": {},
      "chinese": "距离",
      "isBreak": false
    },
    {
      "japanese": "歌手：FictionJunction",
      "furiganaMap": {
        "0": "か",
        "1": "しゅ"
      },
      "chinese": "歌手：FictionJunction",
      "isBreak": false
    },
    {
      "japanese": "作詞/作曲：梶浦由記",
      "furiganaMap": {
        "0": "さく",
        "1": "し",
        "3": "さっ",
        "4": "きょく",
        "6": "かじ",
        "7": "うら",
        "8": "ゆ",
        "9": "き"
      },
      "chinese": "作词/作曲：梶浦由记",
      "isBreak": false
    },
    {
      "japanese": "巡り会った心が　呼びあうよ遠い真実",
      "furiganaMap": {
        "0": "めぐ",
        "2": "あ",
        "5": "こころ",
        "8": "よ",
        "13": "とお",
        "15": "しん",
        "16": "じつ"
      },
      "chinese": "相逢的心灵 正在呼唤那遥远的真实",
      "isBreak": false
    },
    {
      "japanese": "逆巻く波を隔て　同じ夢を叫んだ",
      "furiganaMap": {
        "0": "さか",
        "1": "ま",
        "3": "なみ",
        "5": "へだ",
        "8": "おな",
        "10": "ゆめ",
        "12": "さけ"
      },
      "chinese": "隔着翻卷的波涛 呼喊着同一个梦",
      "isBreak": false
    },
    {
      "japanese": "どうしようもなく　奪い合う日々だから",
      "furiganaMap": {
        "9": "うば",
        "11": "あ",
        "13": "ひ",
        "14": "び"
      },
      "chinese": "因为这是无可奈何彼此争夺的日子",
      "isBreak": false
    },
    {
      "japanese": "ただ頬に触れて　少しだけ微笑んだ",
      "furiganaMap": {
        "2": "ほほ",
        "4": "ふ",
        "8": "すこ",
        "12": "ほほ",
        "13": "え"
      },
      "chinese": "只是轻触脸颊 略微露出微笑",
      "isBreak": false
    },
    {
      "japanese": "ここにいるから　見えない星の歌",
      "furiganaMap": {
        "8": "み",
        "12": "ほし",
        "14": "うた"
      },
      "chinese": "因为我就在这里 唱着看不见的星之歌",
      "isBreak": false
    },
    {
      "japanese": "愛と言う名の幻を奏でて",
      "furiganaMap": {
        "0": "あい",
        "2": "い",
        "4": "な",
        "6": "まぼろし",
        "8": "かな"
      },
      "chinese": "奏响那名为爱的幻影",
      "isBreak": false
    },
    {
      "japanese": "離れていた心が　呼び合うよ遠い真実",
      "furiganaMap": {
        "0": "はな",
        "5": "こころ",
        "8": "よ",
        "10": "あ",
        "13": "とお",
        "15": "しん",
        "16": "じつ"
      },
      "chinese": "曾分离的心 也在呼唤那遥远的真实",
      "isBreak": false
    },
    {
      "japanese": "逆巻く空の向こう　同じ光を見てる",
      "furiganaMap": {
        "0": "さか",
        "1": "まく",
        "3": "そら",
        "5": "む",
        "9": "おな",
        "11": "ひかり",
        "13": "み"
      },
      "chinese": "在翻卷天空的彼方 注视着同一道光",
      "isBreak": false
    },
    {
      "japanese": "柔らかな指で　哀しみを暖めて",
      "furiganaMap": {
        "0": "やわ",
        "4": "ゆび",
        "7": "かな",
        "11": "あたた"
      },
      "chinese": "用柔软的手指 温暖那份哀伤",
      "isBreak": false
    },
    {
      "japanese": "幸福の種が　一つだけ芽吹くように",
      "furiganaMap": {
        "0": "こう",
        "1": "ふく",
        "3": "たね",
        "6": "ひと",
        "10": "め",
        "11": "ぶ"
      },
      "chinese": "愿幸福的种子 只萌发出唯一的一株",
      "isBreak": false
    },
    {
      "japanese": "花のようだね　散って行く光は",
      "furiganaMap": {
        "0": "はな",
        "7": "ち",
        "10": "ゆ",
        "12": "ひかり"
      },
      "chinese": "像花一样啊 那渐渐飘散而去的光",
      "isBreak": false
    },
    {
      "japanese": "愛を信じて何処まで行けるだろう",
      "furiganaMap": {
        "0": "あい",
        "2": "しん",
        "5": "ど",
        "6": "こ",
        "9": "ゆ"
      },
      "chinese": "相信着爱 又能走到哪里去呢",
      "isBreak": false
    },
    {
      "japanese": "明日を照らす歌が　貴方にも響くように",
      "furiganaMap": {
        "0": "あし",
        "1": "た",
        "3": "て",
        "6": "うた",
        "9": "あな",
        "10": "た",
        "13": "ひび"
      },
      "chinese": "愿照亮明天的歌声 也能传达到你那里",
      "isBreak": false
    },
    {
      "japanese": "切なくまだ眩しく　慰めを歌ってる",
      "furiganaMap": {
        "0": "せつ",
        "5": "まぶ",
        "9": "なぐさ",
        "12": "うた"
      },
      "chinese": "既令人心痛又依旧耀眼地 唱着慰藉之歌",
      "isBreak": true
    },
    {
      "japanese": "懐かしい瞳　失われた星の",
      "furiganaMap": {
        "0": "なつ",
        "4": "ひとみ",
        "6": "うしな",
        "10": "ほし"
      },
      "chinese": "令人怀念的眼眸 与那失落的星辰",
      "isBreak": false
    },
    {
      "japanese": "祈りが未来へ　届くまで",
      "furiganaMap": {
        "0": "いの",
        "3": "み",
        "4": "らい",
        "7": "とど"
      },
      "chinese": "直到祈祷传达到未来为止",
      "isBreak": true
    },
    {
      "japanese": "初めて見た光を　取り戻す為の真実",
      "furiganaMap": {
        "0": "はじ",
        "3": "み",
        "5": "ひかり",
        "8": "とり",
        "10": "もど",
        "12": "ため",
        "14": "しん",
        "15": "じつ"
      },
      "chinese": "为了取回最初见到的那道光的真实",
      "isBreak": false
    },
    {
      "japanese": "世界はまだ激しく　安らぎを夢見てる",
      "furiganaMap": {
        "0": "せ",
        "1": "かい",
        "5": "はげ",
        "9": "やす",
        "13": "ゆめ",
        "14": "み"
      },
      "chinese": "世界依旧激烈地 梦想着安宁",
      "isBreak": false
    },
    {
      "japanese": "離れていたこころが　手を伸ばす胸の真実",
      "furiganaMap": {
        "0": "はな",
        "10": "て",
        "12": "の",
        "15": "むね",
        "17": "しん",
        "18": "じつ"
      },
      "chinese": "曾分离的心灵 伸出手去触碰胸中的真实",
      "isBreak": false
    },
    {
      "japanese": "逆巻く空を超えて　同じ光の方へ",
      "furiganaMap": {
        "0": "さか",
        "1": "ま",
        "3": "そら",
        "5": "こ",
        "9": "おな",
        "11": "ひかり",
        "13": "ほう"
      },
      "chinese": "越过翻卷的天空 朝着同一道光的方向",
      "isBreak": false
    }
  ]
}
